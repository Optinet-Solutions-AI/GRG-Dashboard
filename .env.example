# ============================================================================
# .env.example — TEMPLATE. Copy to `.env` and fill in real values.
# `.env` is gitignored and never committed. Next.js loads `.env` automatically,
# and the data scripts read it via `--env-file=.env`.
# ============================================================================

# --- Supabase API (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Database connection (Dashboard → Project Settings → Database → URI) ---
# postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# --- Accounts to provision (npm run accounts:provision) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
VIEWER_EMAIL=
VIEWER_PASSWORD=

# --- Optional: PageSpeed Insights API key (raises quota; works without one) ---
PAGESPEED_API_KEY=

# ============================================================================
# .env.example — TEMPLATE. Copy to `.env` and fill in real values.
# `.env` is gitignored and never committed. Next.js loads `.env` automatically,
# and the data scripts read it via `--env-file=.env`.
# ============================================================================

# --- Supabase API (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Database connection (Dashboard → Project Settings → Database → URI) ---
# postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# --- Accounts to provision (npm run accounts:provision) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
VIEWER_EMAIL=
VIEWER_PASSWORD=

# --- Portal SSO (cross-dashboard single sign-on via the central portal) ---
# Public identifiers (not secrets). The portal-callback route defaults to these values, so
# setting them is OPTIONAL — override only if the portal's issuer/audience/JWKS change.
# SUPABASE_SERVICE_ROLE_KEY (above) IS required for SSO (JIT user provisioning).
PORTAL_JWKS_URL=https://dashboard-portal-tawny.vercel.app/api/sso/jwks
PORTAL_ISSUER=https://dashboard-portal-tawny.vercel.app
SSO_AUDIENCE=e672eab0-8ed4-4034-8ddb-b573d2958eeb

# --- Optional: PageSpeed Insights API key (raises quota; works without one) ---
PAGESPEED_API_KEY=

# --- QA: Google Sheets write-back (optional) ---
# Service-account JSON with Editor access to the QA sheet.
# Without this, syncing in from the sheet still works; edits in the dashboard
# will NOT be written back to the sheet.
# 1. Create a service account in GCP Console → IAM & Admin → Service Accounts
# 2. Download the JSON key
# 3. Share the Google Sheet with the service account email (Editor)
# 4. Paste the entire JSON as a single-line string here (and in Vercel env vars)
GOOGLE_SHEETS_SA_KEY=
